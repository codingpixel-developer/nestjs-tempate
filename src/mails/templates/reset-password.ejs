<!doctype html>
<html>
  <head>
    <title>Reset Your Password - <%= appName %></title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      body {
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #333333;
        background-color: #f5f5f0;
        margin: 0;
        padding: 0;
      }

      .container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }

      .header {
        background: #2d3734;
        padding: 30px 20px;
        text-align: center;
        color: #ffffff;
        border-bottom: 3px solid #4caf50;
      }

      .logo {
        margin-bottom: 15px;
        text-align: center;
      }

      .logo img {
        height: 60px;
        width: auto;
        max-width: 200px;
      }

      .header h1 {
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 8px;
        color: #ffffff;
      }

      .header p {
        font-size: 16px;
        color: #a0a0a0;
      }

      .content {
        padding: 40px 30px;
      }

      .reset-section {
        text-align: center;
        margin-bottom: 30px;
      }

      .reset-section h2 {
        font-size: 24px;
        font-weight: 600;
        color: #333333;
        margin-bottom: 10px;
      }

      .reset-section p {
        font-size: 16px;
        color: #888888;
        margin-bottom: 25px;
      }

      .reset-button {
        display: inline-block;
        background: #4caf50;
        color: #ffffff;
        text-decoration: none;
        padding: 15px 30px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 16px;
        transition: background-color 0.3s ease;
      }

      .reset-button:hover {
        background: #45a049;
      }

      .warning-card {
        background-color: #f5f5f0;
        border: 1px solid #e0e0e0;
        border-radius: 12px;
        padding: 25px;
        margin: 30px 0;
        border-left: 4px solid #4caf50;
      }

      .warning-card h3 {
        font-size: 18px;
        font-weight: 600;
        color: #333333;
        margin-bottom: 15px;
      }

      .warning-list {
        list-style: none;
      }

      .warning-list li {
        padding: 8px 0;
        color: #333333;
        padding-left: 25px;
        position: relative;
      }

      .warning-list li:before {
        content: '⚠️';
        font-size: 14px;
        position: absolute;
        left: 0;
        top: 8px;
      }

      .footer {
        background-color: #f5f5f0;
        padding: 25px 30px;
        text-align: center;
        border-top: 1px solid #e0e0e0;
      }

      .footer p {
        color: #888888;
        font-size: 14px;
        margin-bottom: 10px;
      }

      .footer-links {
        margin-top: 15px;
      }

      .footer-links a {
        color: #4caf50;
        text-decoration: none;
        margin: 0 10px;
        font-size: 14px;
      }

      .footer-links a:hover {
        text-decoration: underline;
      }

      .expiry-notice {
        background-color: #e3f2fd;
        border: 1px solid #bbdefb;
        border-radius: 8px;
        padding: 15px;
        margin: 20px 0;
        font-size: 14px;
        color: #1976d2;
        text-align: center;
      }

      @media (max-width: 600px) {
        .container {
          margin: 10px;
          border-radius: 8px;
        }

        .content {
          padding: 25px 20px;
        }

        .header {
          padding: 25px 15px;
        }

        .logo img {
          height: 50px;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <div class="logo">
          <img
            src="https://unprocessedkitchen.netlify.app/assets/logo-C1eX2Ekv.webp"
            alt="Private Chef"
          />
        </div>
        <h1>Reset Your Password</h1>
        <p>Secure access to your <%= appName %> account</p>
      </div>

      <div class="content">
        <div class="reset-section">
          <h2>Hi <%= name %>,</h2>
          <p>
            We received a request to reset your password for your <%= appName %>
            account. Click the button below to create a new secure password:
          </p>
          <a href="<%= url %>" class="reset-button">Reset Password</a>
        </div>

        <div class="expiry-notice">
          <strong
            >⏰ This link will expire in 24 hours for your security.</strong
          >
        </div>

        <div class="warning-card">
          <h3>⚠️ Didn't request this reset?</h3>
          <ul class="warning-list">
            <li>Ignore this email - your password won't be changed</li>
            <li>Consider changing your password if you're concerned</li>
          </ul>
        </div>
      </div>

      <div class="footer">
        <p>Best regards,<br /><strong>The <%= appName %> Team</strong></p>
        <p style="margin-top: 15px; font-size: 12px; color: #a0a0a0">
          &copy; <%= new Date().getFullYear() %> <%= appName %>. All rights
          reserved.
        </p>
      </div>
    </div>
  </body>
</html>
